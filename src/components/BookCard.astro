---
interface Props {
  title: string;
  titleAr?: string;
  author?: string;
  level?: string;
  href: string;
  type?: string;
  hasPdf?: boolean;
}

const { title, titleAr, author, level, href, type = "matn", hasPdf = false } = Astro.props;

const typeLabel: Record<string, string> = {
  matn: "Matn",
  sharh: "Sharh",
  hashiyah: "Hashiyah",
  nazm: "Nazm",
  "reference-work": "Reference",
  riwayah: "Riwayah",
};
---
<a href={href} class="book-card">
  <div class="book-card__row">
    <span class="book-card__type ui-text">{typeLabel[type] ?? type}</span>
    {level && <span class="book-card__level ui-text" data-level={level}>{level.replace("-", "–")}</span>}
    {hasPdf && (
      <span class="book-card__pdf ui-text" title="PDF available">
        <svg viewBox="0 0 16 16" width="12" height="12" fill="none" aria-hidden="true">
          <path d="M4 2h5l3 3v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.2"/>
        </svg>
      </span>
    )}
  </div>
  <h4 class="book-card__title">{title}</h4>
  {titleAr && <p class="book-card__title-ar" lang="ar">{titleAr}</p>}
  {author && <p class="book-card__author ui-text">{author}</p>}
</a>

<style>
  .book-card {
    display: block;
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--duration-fast) var(--ease-standard),
                background var(--duration-fast) var(--ease-standard);
  }
  .book-card:hover {
    border-color: var(--color-accent);
    background: var(--color-raised);
  }
  .book-card__row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .book-card__type {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .book-card__level {
    font-size: var(--text-xs);
    padding: 1px 7px;
    border-radius: 20px;
    border: 1px solid currentColor;
  }
  .book-card__level[data-level^="beginner"] { color: var(--level-beginner); }
  .book-card__level[data-level^="intermediate"] { color: var(--level-intermediate); }
  .book-card__level[data-level^="advanced"] { color: var(--level-advanced); }

  .book-card__pdf {
    margin-left: auto;
    color: var(--color-accent);
    display: flex;
  }

  .book-card__title {
    font-size: var(--text-base);
    margin: 0 0 2px;
  }
  .book-card__title-ar {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin: 0 0 var(--space-1);
  }
  .book-card__author {
    font-size: var(--text-xs);
    color: var(--color-muted);
    margin: 0;
  }
</style>
