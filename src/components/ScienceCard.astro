---
interface Props {
  title: string;
  titleAr?: string;
  description: string;
  href: string;
  status?: "developed" | "developing" | "stub";
  bookCount?: number;
  featured?: boolean;
}

const { title, titleAr, description, href, status = "developing", bookCount, featured = false } = Astro.props;

const statusLabel: Record<string, string> = {
  developed: "Developed",
  developing: "Developing",
  stub: "Early stage",
};
---
<a href={href} class="science-card" class:list={{ "is-featured": featured }}>
  <div class="science-card__top">
    {featured && (
      <span class="science-card__featured-badge ui-text">
        <svg viewBox="0 0 16 16" width="11" height="11" fill="currentColor" aria-hidden="true">
          <path d="M8 1.5l1.9 4.3 4.6.5-3.5 3.1 1 4.6L8 11.7l-4 2.3 1-4.6L1.5 6.3l4.6-.5L8 1.5Z"/>
        </svg>
        Main focus
      </span>
    )}
    <span class="eyebrow science-card__status" data-status={status}>{statusLabel[status]}</span>
    {typeof bookCount === "number" && (
      <span class="science-card__count ui-text">{bookCount} {bookCount === 1 ? "text" : "texts"}</span>
    )}
  </div>

  <h3 class="science-card__title">{title}</h3>
  {titleAr && <p class="science-card__title-ar" lang="ar">{titleAr}</p>}
  <p class="science-card__desc">{description}</p>

  <span class="science-card__cta ui-text">
    Explore
    <svg viewBox="0 0 16 16" width="13" height="13" fill="none" aria-hidden="true">
      <path d="M3 8h10M8.5 3.5 13 8l-4.5 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </span>
</a>

<style>
  .science-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: border-color var(--duration-base) var(--ease-standard),
                transform var(--duration-base) var(--ease-standard),
                background var(--duration-base) var(--ease-standard);
    height: 100%;
  }
  .science-card:hover {
    border-color: var(--color-accent);
    background: var(--color-raised);
    transform: translateY(-2px);
  }

  .science-card.is-featured {
    border: 1.5px solid var(--color-accent);
    background: linear-gradient(160deg, var(--color-accent-soft), var(--color-surface) 55%);
  }
  .science-card.is-featured:hover {
    background: linear-gradient(160deg, var(--color-accent-soft), var(--color-raised) 55%);
  }

  .science-card__featured-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.03em;
    color: var(--color-accent);
    margin-right: auto;
  }

  .science-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }
  .science-card__status[data-status="developed"] { color: var(--level-beginner); }
  .science-card__status[data-status="developing"] { color: var(--color-accent); }
  .science-card__status[data-status="stub"] { color: var(--color-muted); }
  .science-card__count {
    font-size: var(--text-xs);
    color: var(--color-muted);
  }

  .science-card__title {
    margin-bottom: var(--space-1);
    font-size: var(--text-xl);
  }
  .is-featured .science-card__title { font-size: var(--text-2xl); }
  .science-card__title-ar {
    font-size: var(--text-lg);
    color: var(--color-muted);
    margin: 0 0 var(--space-3);
  }
  .science-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    margin: 0 0 var(--space-4);
    flex-grow: 1;
  }

  .science-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    margin-top: auto;
  }
  .science-card__cta svg {
    transition: transform var(--duration-fast) var(--ease-standard);
  }
  .science-card:hover .science-card__cta svg {
    transform: translateX(3px);
  }
</style>
