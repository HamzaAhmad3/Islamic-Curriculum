---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import IsnadChain from "@/components/IsnadChain.astro";
import { getCommentariesFor, levelLabel } from "@/lib/content";

export async function getStaticPaths() {
  const books = await getCollection("books");
  return books.map((book) => ({
    params: { slug: book.slug },
    props: { book },
  }));
}

const { book } = Astro.props;
const { Content } = await render(book);
const base = import.meta.env.BASE_URL;

const science = await getEntry(book.data.science);
const parent = book.data.parent ? await getEntry(book.data.parent) : null;
const commentaries = await getCommentariesFor(book.slug);

const allScholars = await getCollection("scholars");
const matchedScholar = book.data.author
  ? allScholars.find((s) => s.data.aliases.some((alias) => book.data.author!.includes(alias)))
  : null;

const relatedResolved = await Promise.all(
  book.data.related.map(async (rel) => ({
    ...rel,
    entry: await getEntry(rel.ref),
  }))
);

const relationLabel: Record<string, string> = {
  prerequisite: "Prerequisite",
  "leads-to": "Leads to",
  "alternative-pathway": "Alternative pathway",
  "companion-reading": "Companion reading",
  "evidence-reference": "Evidence reference",
  "mandatory-supplement": "Mandatory supplement",
  "riwayah-variant": "Transmission variant",
  "see-also": "See also",
};

const typeLabel: Record<string, string> = {
  matn: "Matn — primary text",
  sharh: "Sharh — commentary",
  hashiyah: "Hashiyah — marginal gloss",
  nazm: "Nazm — versification",
  "reference-work": "Reference work",
  riwayah: "Riwayah — transmission",
};

function formatDeathDate(d?: { ah?: number; ce?: number; note?: string }) {
  if (!d) return null;
  const parts = [];
  if (d.ah) parts.push(`d. ${d.ah} AH`);
  if (d.ce) parts.push(`${d.ce} CE`);
  if (d.note) parts.push(`(${d.note})`);
  return parts.join(" · ") || null;
}

const deathDateStr = formatDeathDate(book.data.deathDate);
const preferredEdition = book.data.editions.find((e) => e.isPreferred) ?? book.data.editions[0] ?? null;
const hasRecordings = book.data.recordings.length > 0;
---
<BaseLayout title={book.data.title} description={book.data.notes ?? `${book.data.title} — ${science?.data.title ?? ""}`}>
  <div class="breadcrumbs ui-text">
    <a href={`${base}sciences`}>Sciences</a>
    <span aria-hidden="true">/</span>
    {science && <a href={`${base}sciences/${science.slug}`}>{science.data.title}</a>}
    <span aria-hidden="true">/</span>
    <span>{book.data.title}</span>
  </div>

  <article class="book-page">
    <header class="book-hero">
      <div class="book-hero__main">
        <p class="eyebrow book-hero__type">{typeLabel[book.data.type]}</p>
        <h1>{book.data.title}</h1>
        {book.data.titleAr && <p class="book-hero__ar" lang="ar">{book.data.titleAr}</p>}

        {(book.data.pdfUrl || hasRecordings) && (
          <div class="book-actions">
            {book.data.pdfUrl && (
              <a href={book.data.pdfUrl} class="btn btn--pdf" target="_blank" rel="noopener noreferrer">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
                  <path d="M5 3h9l5 5v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <path d="M14 3v5h5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
                Open PDF
              </a>
            )}
            {hasRecordings && (
              <a href="#recordings" class="btn btn--recording">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M10 8.5v7l6-3.5-6-3.5Z" fill="currentColor"/>
                </svg>
                Class recordings
              </a>
            )}
          </div>
        )}

        <dl class="book-meta">
          {science && (
            <div class="book-meta__item">
              <dt>Science</dt>
              <dd><a href={`${base}sciences/${science.slug}`}>{science.data.title}</a></dd>
            </div>
          )}
          <div class="book-meta__item">
            <dt>Type</dt>
            <dd>{typeLabel[book.data.type].split(" — ")[0]}</dd>
          </div>
          {book.data.author && (
            <div class="book-meta__item">
              <dt>Author</dt>
              <dd>
                {matchedScholar ? (
                  <a href={`${base}scholars/${matchedScholar.slug}`}>{book.data.author}</a>
                ) : (
                  book.data.author
                )}
              </dd>
            </div>
          )}
          {deathDateStr && (
            <div class="book-meta__item">
              <dt>Death date</dt>
              <dd>{deathDateStr}</dd>
            </div>
          )}
          {book.data.level && (
            <div class="book-meta__item">
              <dt>Level</dt>
              <dd data-level={book.data.level}>{levelLabel[book.data.level]}</dd>
            </div>
          )}
          {parent && (
            <div class="book-meta__item">
              <dt>Commentary on</dt>
              <dd><a href={`${base}books/${parent.slug}`}>{parent.data.title}</a></dd>
            </div>
          )}
          {preferredEdition && (preferredEdition.publisher || preferredEdition.editor) && (
            <div class="book-meta__item">
              <dt>Best edition</dt>
              <dd>
                {preferredEdition.publisher}
                {preferredEdition.editor && <span class="ui-text"> · ed. {preferredEdition.editor}</span>}
              </dd>
            </div>
          )}
        </dl>

        {book.data.tags.length > 0 && (
          <div class="tag-list tag-list--hero">
            {book.data.tags.map((tag) => (
              <span class="tag ui-text">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>

    {book.body && (
      <section class="book-section prose">
        <Content />
      </section>
    )}

    {book.data.editions.length > 0 && (
      <section class="book-section">
        <h2>Editions</h2>
        <ul class="edition-list">
          {book.data.editions.map((ed) => (
            <li class="edition-item">
              {ed.isPreferred && <span class="edition-item__badge ui-text">Preferred</span>}
              <div>
                {ed.publisher && <strong>{ed.publisher}</strong>}
                {ed.editor && <span class="ui-text"> · ed. {ed.editor}</span>}
                {ed.note && <p class="edition-item__note">{ed.note}</p>}
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

    {commentaries.length > 0 && (
      <section class="book-section">
        <h2>Commentaries</h2>
        <IsnadChain
          nodes={commentaries.map((c) => ({
            label: c.data.title,
            labelAr: c.data.titleAr,
            href: `${base}books/${c.slug}`,
            meta: [c.data.author, c.data.level ? levelLabel[c.data.level] : null].filter(Boolean).join(" · "),
          }))}
        />
      </section>
    )}

    {relatedResolved.length > 0 && (
      <section class="book-section">
        <h2>Related</h2>
        <ul class="related-list">
          {relatedResolved.filter((r) => r.entry).map((r) => (
            <li class="related-item">
              <span class="related-item__kind ui-text">{relationLabel[r.kind]}</span>
              <a href={`${base}books/${r.entry!.slug}`} class="related-item__title">{r.entry!.data.title}</a>
              {r.note && <p class="related-item__note">{r.note}</p>}
            </li>
          ))}
        </ul>
      </section>
    )}

    {book.data.recordings.length > 0 && (
      <section class="book-section" id="recordings">
        <h2>Class recordings</h2>
        <ul class="recording-list">
          {book.data.recordings.map((rec) => (
            <li class="recording-card">
              <div class="recording-card__row">
                {rec.teacher && <strong class="recording-card__teacher">{rec.teacher}</strong>}
                {rec.status && <span class="ui-text recording-card__status" data-status={rec.status}>{rec.status}</span>}
              </div>
              {rec.lastLesson && <p class="recording-card__lesson">Last lesson: {rec.lastLesson}</p>}
              {rec.url && (
                <a href={rec.url} class="btn btn--recording-card" target="_blank" rel="noopener noreferrer">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
                    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M10 8.5v7l6-3.5-6-3.5Z" fill="currentColor"/>
                  </svg>
                  Open recording
                </a>
              )}
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>

  <style>
    .breadcrumbs {
      max-width: 48rem;
      margin: 0 auto;
      padding: var(--space-6) var(--space-6) 0;
      display: flex;
      gap: var(--space-2);
      flex-wrap: wrap;
      font-size: var(--text-xs);
      color: var(--color-muted);
    }
    .breadcrumbs a { color: var(--color-muted); }
    .breadcrumbs a:hover { color: var(--color-accent); }

    .book-page { max-width: 48rem; margin: 0 auto; padding: var(--space-6) var(--space-6) var(--space-24); }

    .book-hero { padding-bottom: var(--space-8); }
    .book-hero__main h1 { margin-bottom: var(--space-4); }
    .book-hero__type { color: var(--color-accent); margin-bottom: var(--space-4); }
    .book-hero__ar { font-size: var(--text-2xl); color: var(--color-muted); margin: 0 0 var(--space-8); }

    .book-meta {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-6);
      margin: 0 0 var(--space-6);
      padding: var(--space-5) 0;
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
    }
    .book-meta__item dt {
      font-family: var(--font-ui);
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-muted);
      margin-bottom: 2px;
    }
    .book-meta__item dd { margin: 0; font-size: var(--text-sm); }
    .book-meta__item dd a { color: var(--color-accent); }
    .book-meta__item dd[data-level^="beginner"] { color: var(--level-beginner); }
    .book-meta__item dd[data-level^="intermediate"] { color: var(--level-intermediate); }
    .book-meta__item dd[data-level^="advanced"] { color: var(--level-advanced); }

    .book-actions {
      display: flex;
      gap: var(--space-3);
      flex-wrap: wrap;
      margin-bottom: var(--space-6);
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-3) var(--space-6);
      border-radius: var(--radius-md);
      font-family: var(--font-ui);
      font-size: var(--text-sm);
      font-weight: 600;
      transition: filter var(--duration-fast) var(--ease-standard), border-color var(--duration-fast) var(--ease-standard);
    }
    .btn--primary { background: var(--color-accent); color: var(--color-ink); }
    .btn--primary:hover { filter: brightness(1.1); }
    .btn--pdf {
      background: var(--color-accent);
      color: var(--color-ink);
    }
    .btn--pdf:hover { filter: brightness(1.1); }
    .btn--recording {
      background: transparent;
      border: 1.5px solid var(--color-accent);
      color: var(--color-accent);
    }
    .btn--recording:hover { background: var(--color-accent-soft); }

    .book-section { padding-top: var(--space-8); border-top: 1px solid var(--color-border); margin-top: var(--space-8); }
    .book-section:first-of-type { margin-top: 0; }
    .book-section h2 { font-size: var(--text-lg); margin-bottom: var(--space-5); }
    .prose :global(p) { font-size: var(--text-lg); line-height: 1.75; }

    .edition-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-4); }
    .edition-item { display: flex; gap: var(--space-3); align-items: baseline; font-size: var(--text-sm); }
    .edition-item > div { min-width: 0; }
    .edition-item__badge {
      flex-shrink: 0;
      font-size: var(--text-xs);
      font-weight: 600;
      color: var(--color-accent);
      border: 1px solid var(--color-accent);
      border-radius: 20px;
      padding: 1px 8px;
    }
    .edition-item__note { color: var(--color-muted); margin: var(--space-1) 0 0; }

    .related-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-4); }
    .related-item__kind {
      display: block;
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-muted);
      margin-bottom: 2px;
    }
    .related-item__title { font-family: var(--font-display); font-size: var(--text-lg); color: var(--color-accent); }
    .related-item__note { font-size: var(--text-sm); color: var(--color-muted); margin: var(--space-1) 0 0; }

    .recording-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-4); }
    .recording-card {
      padding: var(--space-5);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
    }
    .recording-card__row {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      margin-bottom: var(--space-2);
    }
    .recording-card__teacher { font-family: var(--font-display); font-size: var(--text-base); }
    .recording-card__status {
      font-size: var(--text-xs);
      color: var(--color-muted);
      text-transform: capitalize;
      border: 1px solid var(--color-border);
      border-radius: 20px;
      padding: 1px 8px;
    }
    .recording-card__lesson { color: var(--color-muted); font-size: var(--text-sm); margin: 0 0 var(--space-3); }
    .btn--recording-card {
      background: var(--color-raised);
      color: var(--color-accent);
      padding: var(--space-2) var(--space-4);
      font-size: var(--text-xs);
    }
    .btn--recording-card:hover { background: var(--color-accent-soft); }

    .tag-list { display: flex; flex-wrap: wrap; gap: var(--space-3); }
    .tag-list--hero { margin-top: var(--space-3); }
    .tag {
      font-size: var(--text-xs);
      padding: 5px 14px;
      border-radius: 20px;
      background: var(--color-raised);
      color: var(--color-muted);
    }

    @media (max-width: 560px) {
      .book-page { padding: var(--space-4) var(--space-4) var(--space-16); }
      .book-hero__ar { font-size: var(--text-xl); }
      .book-meta { gap: var(--space-4); }
      h1 { font-size: var(--text-3xl); }
    }
  </style>
</BaseLayout>
