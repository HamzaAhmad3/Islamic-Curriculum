---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const base = import.meta.env.BASE_URL;
const science = guide.data.relatedScience ? await getEntry(guide.data.relatedScience) : null;
---
<BaseLayout title={guide.data.title} description={guide.data.summary}>
  <div class="breadcrumbs ui-text">
    <a href={`${base}guides`}>Guides</a>
    <span aria-hidden="true">/</span>
    <span>{guide.data.title}</span>
  </div>

  <article class="guide-page">
    <header class="guide-header">
      {science && <a href={`${base}sciences/${science.slug}`} class="eyebrow guide-header__science">{science.data.title}</a>}
      <h1>{guide.data.title}</h1>
      {guide.data.summary && <p class="guide-header__summary">{guide.data.summary}</p>}
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>

  <style>
    .breadcrumbs {
      max-width: 42rem;
      margin: 0 auto;
      padding: var(--space-6) var(--space-6) 0;
      display: flex;
      gap: var(--space-2);
      font-size: var(--text-xs);
      color: var(--color-muted);
    }
    .breadcrumbs a:hover { color: var(--color-accent); }

    .guide-page { max-width: 42rem; margin: 0 auto; padding: var(--space-6) var(--space-6) var(--space-24); }
    .guide-header { padding-bottom: var(--space-8); border-bottom: 1px solid var(--color-border); margin-bottom: var(--space-8); }
    .guide-header__science { color: var(--color-accent); margin-bottom: var(--space-3); display: inline-block; }
    .guide-header__summary { font-size: var(--text-lg); color: var(--color-text-soft); margin: var(--space-3) 0 0; }

    .prose :global(p) { font-size: var(--text-lg); line-height: 1.8; margin-bottom: var(--space-5); }
    .prose :global(h2) { font-size: var(--text-xl); margin-top: var(--space-10); }
    .prose :global(h3) { font-size: var(--text-lg); margin-top: var(--space-8); }
  </style>
</BaseLayout>
