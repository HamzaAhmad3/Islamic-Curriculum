---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const books = await getCollection("books");
const base = import.meta.env.BASE_URL;

const booksWithEditions = await Promise.all(
  books
    .filter((b) => b.data.editions.length > 0)
    .map(async (b) => ({ book: b, science: await getEntry(b.data.science) }))
);

const preferredCount = books.reduce(
  (sum, b) => sum + b.data.editions.filter((e) => e.isPreferred).length,
  0
);
---
<BaseLayout title="Library" description="Preferred editions and publishers, gathered from across the catalog.">
  <div class="page-header">
    <p class="eyebrow">Editions and publishers</p>
    <h1>Library</h1>
    <p class="page-header__lede">
      A cross-catalog view of recommended editions — which print, which editor, which publisher —
      pulled from every book's own page. {preferredCount > 0 && `${preferredCount} preferred editions marked so far.`}
    </p>
  </div>

  <div class="section-inner">
    {booksWithEditions.length === 0 ? (
      <p class="empty-state">
        No edition data has been added yet. As books are catalogued with preferred publishers and
        editors, they'll appear here automatically.
      </p>
    ) : (
      <ul class="library-list">
        {booksWithEditions.map(({ book, science }) => (
          <li class="library-item">
            <div class="library-item__head">
              <a href={`${base}books/${book.slug}`} class="library-item__title">{book.data.title}</a>
              {science && <span class="library-item__science ui-text">{science.data.title}</span>}
            </div>
            <ul class="edition-sublist">
              {book.data.editions.map((ed) => (
                <li>
                  {ed.isPreferred && <span class="edition-badge ui-text">Preferred</span>}
                  {ed.publisher && <strong>{ed.publisher}</strong>}
                  {ed.editor && <span class="ui-text"> · ed. {ed.editor}</span>}
                  {ed.note && <p class="edition-note">{ed.note}</p>}
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    )}
  </div>

  <style>
    .page-header {
      max-width: 78rem;
      margin: 0 auto;
      padding: var(--space-16) var(--space-6) var(--space-10);
    }
    .page-header h1 { margin: var(--space-3) 0 var(--space-3); }
    .page-header__lede { color: var(--color-text-soft); max-width: 36rem; margin: 0; }

    .section-inner { max-width: 60rem; margin: 0 auto; padding: 0 var(--space-6) var(--space-16); }

    .empty-state {
      color: var(--color-muted);
      font-style: italic;
      padding: var(--space-8);
      border: 1px dashed var(--color-border);
      border-radius: var(--radius-md);
      text-align: center;
    }

    .library-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-6); }
    .library-item {
      padding: var(--space-5);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
    }
    .library-item__head {
      display: flex;
      align-items: baseline;
      gap: var(--space-3);
      margin-bottom: var(--space-3);
      flex-wrap: wrap;
    }
    .library-item__title { font-family: var(--font-display); font-size: var(--text-lg); }
    .library-item__title:hover { color: var(--color-accent); }
    .library-item__science {
      font-size: var(--text-xs);
      color: var(--color-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .edition-sublist { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-3); }
    .edition-sublist li { font-size: var(--text-sm); }
    .edition-badge {
      display: inline-block;
      font-size: var(--text-xs);
      font-weight: 600;
      color: var(--color-accent);
      border: 1px solid var(--color-accent);
      border-radius: 20px;
      padding: 1px 8px;
      margin-right: var(--space-2);
    }
    .edition-note { color: var(--color-muted); margin: var(--space-1) 0 0; }
  </style>
</BaseLayout>
