---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const entries = await getCollection("dashboard");
const base = import.meta.env.BASE_URL;

async function resolveEntry(e: (typeof entries)[number]) {
  const book = e.data.book ? await getEntry(e.data.book) : null;
  return { ...e, resolvedBook: book };
}

const resolved = await Promise.all(entries.map(resolveEntry));

const grouped = {
  studying: resolved.filter((e) => e.data.status === "studying" && !e.data.dateNote),
  recordings: resolved.filter((e) => e.data.status === "studying" && e.data.dateNote),
  reading: resolved.filter((e) => e.data.status === "reading"),
  memorizing: resolved.filter((e) => e.data.status === "memorizing"),
  toBuy: resolved
    .filter((e) => e.data.status === "to-buy")
    .sort((a, b) => (a.data.priority ?? 999) - (b.data.priority ?? 999)),
};

function displayTitle(e: (typeof resolved)[number]) {
  return e.resolvedBook?.data.title ?? e.data.label ?? "Untitled";
}
function displayHref(e: (typeof resolved)[number]) {
  return e.resolvedBook ? `${base}books/${e.resolvedBook.slug}` : null;
}
function displayTitleAr(e: (typeof resolved)[number]) {
  return e.resolvedBook?.data.titleAr ?? null;
}
function displayEdition(e: (typeof resolved)[number]) {
  const editions = e.resolvedBook?.data.editions ?? [];
  const preferred = editions.find((ed) => ed.isPreferred) ?? editions[0];
  if (!preferred) return null;
  return [preferred.publisher, preferred.editor && `ed. ${preferred.editor}`].filter(Boolean).join(" · ") || null;
}
---
<BaseLayout title="Dashboard" description="What's currently being studied, read, and memorized — a personal, evolving snapshot.">
  <div class="page-header">
    <p class="eyebrow">Personal, updated most days</p>
    <h1>Dashboard</h1>
    <p class="page-header__lede">
      A snapshot of what's currently in progress — not part of the catalog itself, just where the
      curator's own study happens to be right now.
    </p>
  </div>

  <div class="dashboard-grid">
    <section class="dash-panel">
      <h2 class="dash-panel__title ui-text">
        <span class="dash-dot" data-status="studying"></span>
        Currently studying
      </h2>
      {grouped.studying.length === 0 ? (
        <p class="empty">Nothing logged yet.</p>
      ) : (
        <ul class="dash-list">
          {grouped.studying.map((e) => (
            <li class="dash-item">
              <span class="dash-item__bullet" aria-hidden="true"></span>
              <div class="dash-item__body">
                {displayHref(e) ? (
                  <a href={displayHref(e)!} class="dash-item__title">{displayTitle(e)}</a>
                ) : (
                  <span class="dash-item__title">{displayTitle(e)}</span>
                )}
                <div class="dash-item__meta ui-text">
                  {e.data.teacher && <span>{e.data.teacher}</span>}
                  {e.data.progress && <span>{e.data.progress}</span>}
                </div>
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>

    <section class="dash-panel">
      <h2 class="dash-panel__title ui-text">
        <span class="dash-dot" data-status="reading"></span>
        Reading
      </h2>
      {grouped.reading.length === 0 ? (
        <p class="empty">Nothing logged yet.</p>
      ) : (
        <ul class="dash-list">
          {grouped.reading.map((e) => (
            <li class="dash-item">
              <span class="dash-item__bullet" aria-hidden="true"></span>
              <div class="dash-item__body">
                {displayHref(e) ? (
                  <a href={displayHref(e)!} class="dash-item__title">{displayTitle(e)}</a>
                ) : (
                  <span class="dash-item__title">{displayTitle(e)}</span>
                )}
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>

    <section class="dash-panel">
      <h2 class="dash-panel__title ui-text">
        <span class="dash-dot" data-status="memorizing"></span>
        Memorizing
      </h2>
      {grouped.memorizing.length === 0 ? (
        <p class="empty">Nothing logged yet.</p>
      ) : (
        <ul class="dash-list">
          {grouped.memorizing.map((e) => (
            <li class="dash-item">
              <span class="dash-item__bullet" aria-hidden="true"></span>
              <div class="dash-item__body">
                <span class="dash-item__title">{displayTitle(e)}</span>
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>

    <section class="dash-panel">
      <h2 class="dash-panel__title ui-text">
        <span class="dash-dot" data-status="recordings"></span>
        Class recordings in progress
      </h2>
      {grouped.recordings.length === 0 ? (
        <p class="empty">Nothing logged yet.</p>
      ) : (
        <ul class="dash-list">
          {grouped.recordings.map((e) => (
            <li class="dash-item">
              <span class="dash-item__bullet" aria-hidden="true"></span>
              <div class="dash-item__body">
                {displayHref(e) ? (
                  <a href={displayHref(e)!} class="dash-item__title">{e.data.label ?? displayTitle(e)}</a>
                ) : (
                  <span class="dash-item__title">{e.data.label ?? displayTitle(e)}</span>
                )}
                <div class="dash-item__meta ui-text">
                  {e.data.dateNote && <span>{e.data.dateNote}</span>}
                </div>
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>
  </div>

  <section class="section">
    <div class="section-inner">
      <div class="section-heading-row">
        <h2>To buy</h2>
        <p class="section-heading-row__note ui-text">Listed in order of priority, most wanted first</p>
      </div>
      <ul class="buy-list">
        {grouped.toBuy.map((e) => (
          <li class="buy-item">
            <span class="buy-item__bullet" aria-hidden="true"></span>
            <div class="buy-item__main">
              <div class="buy-item__title-row">
                {displayHref(e) ? (
                  <a href={displayHref(e)!} class="buy-item__title">{displayTitle(e)}</a>
                ) : (
                  <span class="buy-item__title">{displayTitle(e)}</span>
                )}
                {e.data.rare && <span class="buy-item__rare ui-text">Rare</span>}
              </div>
              {e.data.note && <p class="buy-item__note">{e.data.note}</p>}
            </div>
            <div class="buy-item__side">
              {displayTitleAr(e) && <span class="buy-item__ar" lang="ar">{displayTitleAr(e)}</span>}
              {displayEdition(e) && <span class="buy-item__edition ui-text">{displayEdition(e)}</span>}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    .page-header {
      max-width: 78rem;
      margin: 0 auto;
      padding: var(--space-16) var(--space-6) var(--space-10);
    }
    .page-header h1 { margin: var(--space-3) 0 var(--space-4); }
    .page-header__lede { color: var(--color-text-soft); max-width: 34rem; margin: 0; }

    .dashboard-grid {
      max-width: 78rem;
      margin: 0 auto;
      padding: 0 var(--space-6) var(--space-16);
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--space-6);
    }

    .dash-panel {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: var(--space-8);
    }
    .dash-panel__title {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      font-size: var(--text-sm);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--color-muted);
      margin: 0 0 var(--space-6);
    }
    .dash-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--color-accent);
      flex-shrink: 0;
    }

    .dash-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-5); }
    .dash-item {
      display: flex;
      align-items: flex-start;
      gap: var(--space-3);
    }
    .dash-item__bullet {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--color-muted);
      flex-shrink: 0;
      margin-top: 9px;
    }
    .dash-item__body {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }
    .dash-item__title {
      font-family: var(--font-display);
      font-size: var(--text-base);
      color: var(--color-text);
      line-height: 1.5;
    }
    a.dash-item__title:hover { color: var(--color-accent); }
    .dash-item__meta {
      display: flex;
      gap: var(--space-4);
      font-size: var(--text-xs);
      color: var(--color-muted);
    }

    .empty { color: var(--color-muted); font-size: var(--text-sm); font-style: italic; margin: 0; }

    .section { border-top: 1px solid var(--color-border); padding: var(--space-12) 0 var(--space-16); }
    .section-inner { max-width: 78rem; margin: 0 auto; padding: 0 var(--space-6); }
    .section-heading-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: var(--space-3);
      margin-bottom: var(--space-8);
    }
    .section-heading-row h2 { margin: 0; }
    .section-heading-row__note {
      font-size: var(--text-xs);
      color: var(--color-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .buy-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      max-width: 46rem;
    }
    .buy-item {
      display: flex;
      align-items: flex-start;
      gap: var(--space-4);
      padding: var(--space-5) var(--space-6);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      background: var(--color-surface);
    }
    .buy-item__bullet {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--color-accent);
      flex-shrink: 0;
      margin-top: 9px;
    }
    .buy-item__main {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      min-width: 0;
      flex: 1;
    }
    .buy-item__title-row {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      flex-wrap: wrap;
    }
    .buy-item__title { font-size: var(--text-base); }
    .buy-item a.buy-item__title:hover { color: var(--color-accent); }
    .buy-item__note {
      font-size: var(--text-sm);
      color: var(--color-muted);
      margin: 0;
      line-height: 1.6;
    }
    .buy-item__rare {
      flex-shrink: 0;
      font-size: var(--text-xs);
      color: var(--color-danger);
      border: 1px solid var(--color-danger);
      border-radius: 20px;
      padding: 3px 10px;
    }
    .buy-item__side {
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 3px;
      text-align: right;
      padding-top: 2px;
    }
    .buy-item__ar {
      font-size: var(--text-base);
      color: var(--color-text-soft);
    }
    .buy-item__edition {
      font-size: var(--text-xs);
      color: var(--color-muted);
    }

    @media (max-width: 560px) {
      .page-header { padding-top: var(--space-8); }
      .page-header h1 { font-size: var(--text-3xl); }
      .buy-item { padding: var(--space-4); gap: var(--space-3); flex-wrap: wrap; }
      .buy-item__side { flex-direction: row; align-items: center; text-align: left; margin-left: 22px; }
    }
  </style>
</BaseLayout>
